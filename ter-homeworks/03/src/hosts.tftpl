[webservers]
%{ for vm in web_vms ~}
${vm.name} ansible_host=${vm.network_interface[0].nat_ip_address} fqdn=${vm.fqdn}
%{ endfor ~}

[databases]
%{ for vm in db_vms ~}
${vm.name} ansible_host=${vm.network_interface[0].ip_address} fqdn=${vm.fqdn}
%{ endfor ~}

[storage]
%{ if storage_vm != null ~}
${storage_vm.name} ansible_host=${storage_vm.network_interface[0].ip_address} fqdn=${storage_vm.fqdn}
%{ endif ~}